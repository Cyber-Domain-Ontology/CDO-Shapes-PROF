# imports: http://www.w3.org/ns/dx/prof/1.0

@prefix cdo-prof: <http://example.org/ontology/cdo-prof/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prof: <http://www.w3.org/ns/dx/prof/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/ontology/cdo-prof>
	a owl:Ontology ;
	rdfs:comment "This ontology supplements PROF to describe links between the various ontologies, shapes graphs, and other profiles near to PROF."@en ;
	dct:conformsTo <http://example.org/shapes/sh-prof> ;
	owl:imports prof:1.0 ;
	.

